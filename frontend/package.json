{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "check": "vue-tsc --build",
    "build": "pnpm run check && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "format": "oxfmt src/ && oxlint --fix src/",
    "format-check": "oxfmt --check src/ && oxlint src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/vue-query": "^5.92.9",
    "ky": "^1.14.3",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "oxfmt": "^0",
    "oxlint": "^1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  }
}
