{
  "lacuna": {
    "logging": {
      "format": "console",
      "level": "info"
    },
    "identity_header": "Tailscale-User-Login"
  },
  "providers": {
    "anthropic": {
      "name": "Anthropic",
      "baseurl": "https://api.anthropic.com",
      "authorization": {
        "type": "x-api-key",
        "apikey": "${ANTHROPIC_API_KEY}"
      },
      "capability": {
        "models": {},
        "user_agents": []
      },
      "compatibility": {
        "anthropic_messages": true
      }
    },
    "bedrock": {
      "name": "AWS Bedrock",
      "baseurl": "https://bedrock-runtime.us-east-1.amazonaws.com",
      "authorization": {
        "type": "bearer",
        "apikey": "${BEDROCK_API_KEY}"
      },
      "capability": {
        "models": {},
        "user_agents": []
      },
      "compatibility": {
        "bedrock_model_invoke": true
      },
      "headers": {
        "x-foo": "bar"
      }
    }
  }
}
